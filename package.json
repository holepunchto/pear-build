{
  "name": "pear-build",
  "version": "0.2.0",
  "main": "index.js",
  "type": "commonjs",
  "bin": "bin.js",
  "description": "Assemble project deployment folder",
  "author": "Holepunch Inc",
  "license": "Apache-2.0",
  "files": [
    "index.js",
    "bin.js"
  ],
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    }
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "prettier --check . && lunte",
    "test": "npm run test:node && npm run test:bare",
    "test:bare": "brittle-bare --coverage test/all.js",
    "test:node": "brittle-node --coverage test/all.js"
  },
  "dependencies": {
    "bare-fs": "^4.5.3",
    "bare-path": "^3.0.0",
    "localdrive": "^2.2.1",
    "paparam": "^1.10.0"
  },
  "devDependencies": {
    "bare-fs": "^4.5.3",
    "brittle": "^3.19.1",
    "lunte": "^1.6.0",
    "mirror-drive": "^1.13.0",
    "prettier": "^3.7.4",
    "prettier-config-holepunch": "^2.0.0",
    "test-tmp": "^1.4.0"
  }
}
